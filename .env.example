# Copy to .env (or just export these) — all optional.

# --- Notifications: get a tappable link on your phone ---
# Create a bot with @BotFather, then message it once and read the chat id from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Public access to the live view (NAT traversal) ---
# The take-over link must be reachable from your phone, not just the LAN.
#
# TUNNEL picks how: auto (default) | cloudflared | ngrok | localtunnel | lan
#   auto        -> tries cloudflared, then ngrok, then localtunnel, then LAN
#   cloudflared -> free https://<x>.trycloudflare.com, no account. If the binary
#                  isn't installed it's fetched once into ~/.cache/volleybot.
#   ngrok       -> uses the ngrok CLI; needs a (free) authtoken below or configured
#   localtunnel -> https://<x>.loca.lt via npx (no account; has a click-through page)
#   lan         -> no tunnel, same-Wi-Fi only
TUNNEL=auto
NGROK_AUTHTOKEN=
# Bring your own tunnel / reverse proxy — always wins if set:
PUBLIC_BASE_URL=

# --- Browser ---
# false = headful (far more reliable against Cloudflare; run under Xvfb on a
# headless server, e.g. `xvfb-run -a node examples/ashby.js`). Default headless.
# Headful forces --ozone-platform=x11 so it works on Wayland desktops (via
# XWayland) and under Xvfb. Needs a reachable X display ($DISPLAY set, or Xvfb).
HEADLESS=true
CHROME_PATH=/usr/bin/chromium
USER_DATA_DIR=./.chrome-profile
# Extra Chromium flags, space-separated. e.g. to prefer native Wayland instead:
#   CHROME_ARGS=--ozone-platform=wayland
CHROME_ARGS=

# --- Server ---
PORT=7411
